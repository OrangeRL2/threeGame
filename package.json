    "mongodb": "^6.12.0",
    "socket.io-client": "^4.8.1",
    "three": "^0.165.0",
    "vite": "^6.0.7",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5"
